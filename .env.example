# Application Configuration
APP_NAME="Examination Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Logging Configuration
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration - MySQL (Default)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=examination_system
DB_USERNAME=root
DB_PASSWORD=

# Database Configuration - PostgreSQL (Alternative)
# Uncomment below and comment out MySQL configuration to use PostgreSQL
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=examination_system
# DB_USERNAME=postgres
# DB_PASSWORD=

# Cache and Session Configuration
# Using Redis for better performance
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# DomPDF Configuration
DOMPDF_ENABLE_REMOTE=false
DOMPDF_ENABLE_CSS_FLOAT=true
DOMPDF_ENABLE_HTML5_PARSER=true

# Application Specific Settings
# Degree requirement for progress calculation (in credits)
DEGREE_REQUIRED_CREDITS=120

# Performance Settings
RESULTS_PER_PAGE=20
CACHE_TTL=3600

# Testing Environment
# Set to true when running tests
TESTING=false
